# GlobalCore Feedback System - Environment Configuration Example
# Copy this file to .env and fill in the actual values.

# Database connection URL
# Example: postgresql://username:password@localhost:5432/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/global_core_db

# Admin User Configuration
ADMIN_EMAIL=admin@globalcore.com
ADMIN_PASSWORD=change_this_to_a_secure_password
ADMIN_NAME=GlobalCore Admin

# Security
SECRET_KEY=generate_a_random_secret_key_here

# Other sensitive variables
PAMA_PASSWORD=change_me
